VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Well Finder — public URL of the wells.pmtiles archive in Firebase Storage.
# When unset, the map falls back to live paginated RRC ArcGIS queries.
# See functions/src/wellFinder/README.md for the deployment steps.
VITE_WELL_FINDER_PMTILES_URL=

# Labor Pool — Census Bureau ACS Data API key (county demographics).
# Required for local dev only. In production the Cloudflare Worker injects
# the key server-side from its own Variables & Secrets, so the client
# bundle never contains it. For dev, paste the same key here so the Vite
# proxy forwards requests with `&key=...` to api.census.gov.
#
# IMPORTANT for production deploy: the Cloudflare dashboard variable MUST
# be added as a **Secret** (encrypted), not Plaintext, under the Worker's
# top-level Variables and Secrets section. Plaintext variables in that
# section are not exposed to the Worker's runtime `env` parameter for this
# project's deployment type — only Secrets get bound to the runtime.
#
# Free signup (instant): https://api.census.gov/data/key_signup.html
VITE_CENSUS_API_KEY=

# Labor Pool — Bureau of Labor Statistics API key (QCEW + OEWS wages).
# Optional. Without a key, requests are capped at 25/day per IP. With a free
# key, the quota becomes 500/day per key.
# Free signup (instant): https://data.bls.gov/registrationEngine/
VITE_BLS_API_KEY=

# Political Radar — Congress.gov ingest is now SERVER-SIDE.
#
# The browser no longer calls Congress.gov directly. Two scheduled Cloud
# Functions (`refreshFederalBills` daily, `refreshFederalOfficials` weekly)
# pull bills + officials and write them to Firestore; the client just reads
# the cached collections. The API key lives only in Firebase secrets:
#
#   firebase functions:secrets:set CONGRESS_API_KEY
#
# Free key registration: https://api.congress.gov/sign-up/
# (No client-side env var needed for Political Radar anymore.)
