VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Well Finder — public URL of the wells.pmtiles archive in Firebase Storage.
# When unset, the map falls back to live paginated RRC ArcGIS queries.
# See functions/src/wellFinder/README.md for the deployment steps.
VITE_WELL_FINDER_PMTILES_URL=

# Political Radar — Congress.gov API key for the federal layer (active bills
# + House rep + senator details). Free key, register at
# https://api.congress.gov/sign-up/. Without this key, the bills + contacts
# signals fall back to "data unavailable" instead of misleading green ticks.
VITE_CONGRESS_API_KEY=
